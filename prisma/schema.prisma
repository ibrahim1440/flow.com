generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id                String   @id @default(cuid())
  name              String
  username          String?  @unique
  pin               String
  password          String?
  role              String   // admin, inventory, roasting, qc, dispatch, custom
  permissions       String   @default("{}")
  defaultRoute      String   @default("/dashboard")
  active            Boolean  @default(true)
  phoneNumber       String?
  preferredLanguage String   @default("ar")  // "ar" | "en"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  qcRecords         QcRecord[]
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  phone       String?
  email       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model GreenBean {
  id            String   @id @default(cuid())
  serialNumber  String   @unique
  beanType      String
  country       String
  region        String?
  variety       String?
  process       String?
  altitude      String?
  location      String?
  quantityKg    Float    @default(0)
  receivedDate  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orderItems    OrderItem[]
  roastingBatches RoastingBatch[]
}

model Order {
  id                    String   @id @default(cuid())
  orderNumber           Int      @unique
  customerId            String
  customer              Customer @relation(fields: [customerId], references: [id])
  quotationNumber       String?
  quotationSentDate     DateTime?
  approvalStatus        String   @default("Pending") // Pending, Yes, No
  approvalDate          DateTime?
  paymentStatus         String   @default("Not Paid") // Paid, Not Paid, Partial Paid
  vatInvoiceStatus      String   @default("Not Yet") // Sent, Not Yet, Not Paid
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  items                 OrderItem[]
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  greenBeanId       String?
  greenBean         GreenBean? @relation(fields: [greenBeanId], references: [id])
  beanTypeName      String
  quantityKg        Float
  productionStatus  String   @default("Pending") // Pending, In Production, Completed, Order cancelled
  deliveryStatus    String   @default("Not Yet") // Not Yet, Partial Delivered, Delivered
  deliveredQty      Float    @default(0)
  remainingQty      Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  roastingBatches   RoastingBatch[]
  deliveries        Delivery[]
}

model RoastingBatch {
  id                  String   @id @default(cuid())
  orderItemId         String
  orderItem           OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  batchNumber         String   @unique
  date                DateTime @default(now())
  greenBeanId         String?
  greenBean           GreenBean? @relation(fields: [greenBeanId], references: [id])
  greenBeanQuantity   Float
  roastedBeanQuantity Float    @default(0)
  wasteQuantity       Float    @default(0)
  roastProfile        String?
  status              String   @default("Pending QC")

  // Packaging (filled post-QC)
  bags3kg             Int      @default(0)
  bags1kg             Int      @default(0)
  bags250g            Int      @default(0)
  bags150g            Int      @default(0)
  samplesGrams        Float    @default(0)

  // Blending lineage
  blendTiming         String?
  parentBatchId       String?
  parentBatch         RoastingBatch? @relation("BlendLineage", fields: [parentBatchId], references: [id])
  childBatches        RoastingBatch[] @relation("BlendLineage")

  // Multi-tester QC panel
  qcDeadline          DateTime?
  qcToken             String?  @unique
  qcClosedById        String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  qcRecords           QcRecord[]
}

model QcRecord {
  id              String   @id @default(cuid())
  batchId         String
  batch           RoastingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  coffeeOrigin    String
  processing      String
  serialNumber    String
  onProfile       Boolean  @default(false)
  underDeveloped  Boolean  @default(false)
  overDeveloped   Boolean  @default(false)
  color           Int?
  remarks         String?
  // Multi-tester panel fields
  employeeId      String?
  employee        Employee? @relation(fields: [employeeId], references: [id])
  isExternal      Boolean  @default(false)
  testerName      String?
  decision        String   @default("Accept")  // "Accept" or "Reject"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Delivery {
  id            String   @id @default(cuid())
  orderItemId   String
  orderItem     OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  date          DateTime @default(now())
  quantityKg    Float
  deliveryType  String   // full, partial
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CoffeeProduct {
  id            String   @id @default(cuid())
  productNameEn String
  productNameAr String?
  countryEn     String
  countryAr     String?
  regionEn      String?
  regionAr      String?
  varietyEn     String?
  varietyAr     String?
  processEn     String?
  processAr     String?
  altitude      String?
  cupNotesEn    String?
  cupNotesAr    String?
  roastPathEn   String?
  roastPathAr   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

# ═══════════════════════════════════════════════════════════════════════════════
#  HIQBAH COFFEE — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  Never commit the real .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
#
# Get both URLs from your database provider:
#
#  Supabase  →  Project Settings → Database → Connection string
#               DATABASE_URL : "Transaction" mode  (port 6543)
#               DIRECT_URL   : "Session" mode      (port 5432)
#
#  Neon      →  Project Dashboard → Connection Details
#               DATABASE_URL : Pooled connection string
#               DIRECT_URL   : Direct (non-pooled) connection string
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
#
# Generate a strong secret (minimum 32 characters):
#   openssl rand -base64 32
#
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters"
